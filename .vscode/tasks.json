{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Copilot: AppInspect self-heal",
      "type": "process",
      "command": "${workspaceFolder}/.venv/bin/copilot",
      "args": ["appinspect", "fixtures/appinspect/broken_app"],
      "problemMatcher": [],
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true },
      "detail": "Heal the broken AppInspect fixture to green (no Splunk required)."
    },
    {
      "label": "Copilot: SPL lint self-heal",
      "type": "process",
      "command": "${workspaceFolder}/.venv/bin/copilot",
      "args": ["lint", "fixtures/spl_lint/costly_search.spl"],
      "problemMatcher": [],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true },
      "detail": "Rewrite a costly SPL search until it is cost-clean (no Splunk required)."
    },
    {
      "label": "Copilot: Onboard (live MCP)",
      "type": "process",
      "command": "${workspaceFolder}/.venv/bin/copilot",
      "args": ["onboard", "fixtures/onboarding/sample_upi.log"],
      "problemMatcher": [],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true },
      "detail": "Validate extraction candidates through the Splunk MCP server (needs Splunk + .env)."
    },
    {
      "label": "Copilot: Live stream server",
      "type": "process",
      "command": "${workspaceFolder}/.venv/bin/copilot",
      "args": ["serve"],
      "isBackground": true,
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "detail": "Start the SSE server for the dashboard's Go Live mode."
    },
    {
      "label": "Copilot: Dashboard (replay UI)",
      "type": "shell",
      "command": "bun install && bun run dev",
      "options": { "cwd": "${workspaceFolder}/ui/dashboard" },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "detail": "Install deps and start the replay dashboard (no Splunk required)."
    },
    {
      "label": "Copilot: Run Python tests",
      "type": "process",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": ["-m", "pytest", "-q"],
      "problemMatcher": [],
      "group": { "kind": "test", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true },
      "detail": "Run the Python self-heal test suite."
    }
  ]
}
