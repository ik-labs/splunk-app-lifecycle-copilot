# Splunk container credentials. Copy this file to .env and replace values.
SPLUNK_HOST=localhost
SPLUNK_WEB_PORT=8000
SPLUNK_HEC_PORT=8088
SPLUNK_MGMT_PORT=8089
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=change-this-password-123
SPLUNK_HEC_TOKEN=00000000-0000-0000-0000-000000000000

# Splunk MCP Server app.
# Use the endpoint shown by the Splunk MCP Server app after installation.
SPLUNK_MCP_ENDPOINT=https://localhost:8089/services/mcp

# This is the encrypted token generated by the Splunk MCP Server app.
# It is not a plain Splunk REST bearer token and cannot be used for direct REST calls.
SPLUNK_MCP_ENCRYPTED_TOKEN=replace-with-mcp-app-generated-encrypted-token

# Optional. The saia_* MCP tools only appear when Splunk AI Assistant is installed.
SPLUNK_AI_ASSISTANT_AVAILABLE=false
